var.log.OR <- 1/c.table[1,1] + 1/c.table[1,2] +
1/c.table[2,1] + 1/c.table[2,2]
OR.CI <- exp(log(OR.hat) + qnorm(p = c(alpha/2, 1-alpha/2)) *
sqrt(var.log.OR))
round(OR.CI, 4)
rev(round(1/OR.CI, 4))
