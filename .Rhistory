rev(round(1/RR.ci, 4))  # inverted
# Function to calculate relative risk and CI
RR <- function(data, alpha = 0.05, digits = 4) {
n1 <- sum(data[1,])
n2 <- sum(data[2,])
pi.hat.table <- data/rowSums(data)
pi.hat1      <- pi.hat.table[1,1]
pi.hat2      <- pi.hat.table[2,1]
RR.hat       <- pi.hat1/pi.hat2
var.log.RR <- 1/data[1,1] - 1/sum(data[1,]) +
1/data[2,1] - 1/sum(data[2,])
RR.CI <- exp(log(pi.hat1/pi.hat2) +
qnorm(p = c(alpha/2, 1-alpha/2)) * sqrt(var.log.RR))
round(data.frame(Estimate = RR.hat,
Lower = RR.CI[1],
Upper = RR.CI[2],
row.names = ""),
digits)
}
RR(data = c.table, alpha = 0.05, digits = 4)
RR(data = c.table)  # Use defaults
save.res <- RR(data = c.table, alpha = 0.05)
save.res[,1]
save.res[,2:3]
save.res$Estimate
save.res$Lower
save.res$Upper
