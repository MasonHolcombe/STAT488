predicted_pos = (TP + FP)
PPV = TP / (TP + FP)
alpha = 0.01
ptilde = (TP + qnorm(p = 1-alpha/2)^2 /2) / (predicted_pos+qnorm(1-alpha/2)^2)
score = ptilde +
qnorm(p = c(alpha/2, 1-alpha/2)) * sqrt(predicted_pos) /
(predicted_pos+qnorm(1-alpha/2)^2) *sqrt(PPV*(1-PPV) +
qnorm(1-alpha/2)^2/(4*predicted_pos))
(round(PPV, 4))
(round(score, 4))
data = matrix(c(118, 155, 93, 51), nrow = 2)
rownames(data) = c("Non-English", "Native-English")
colnames(data) = c("Funny", "Not-Funny")
